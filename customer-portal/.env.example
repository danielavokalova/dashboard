# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional – future integrations ───────────────────────────────────────────
# GITBOOK_API_KEY=         # Pull docs directly from GitBook space
# METABASE_EMBED_TOKEN=    # Signed embed token for Agency Health charts
# GOOGLE_SHEETS_CREDS=     # Path to service-account JSON for Sheets data
